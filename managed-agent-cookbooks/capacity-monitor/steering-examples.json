[
  {
    "id": "cm-001",
    "label": "Healthy run — no capacity constraints",
    "description": "Standard scheduled run where CS headroom is well above threshold. Confirms silent-green pattern: HEALTHY alert still posts to confirm the monitor ran.",
    "input": {
      "practice_profile": {
        "company_name": "Acme CS Consulting",
        "primary_segment": "Mid-Market",
        "current_arr": 8000000,
        "arr_per_csm": 1500000,
        "current_csm_count": 8,
        "csm_avg_ramp_days": 90,
        "target_growth_pct": 0.20,
        "nrr_current": 1.08,
        "uog_baseline_path": ""
      },
      "hubspot_connected": true,
      "preview_mode": false,
      "alert_channel": "#revops-alignment"
    },
    "expected_behavior": {
      "capacity_reader": {
        "max_supported_arr": 12000000,
        "cs_headroom_pct": 50.0,
        "threshold_label": "HEALTHY",
        "alert_level": "HEALTHY",
        "csms_to_hire": 0,
        "hire_by_date": null,
        "hire_by_urgency": null,
        "confidence": "Moderate"
      },
      "capacity_reporter": {
        "format_used": "HEALTHY",
        "channels_posted": ["#revops-alignment"],
        "cc_channel_used": false,
        "g2_disclaimer_included": false,
        "delivery_status": "posted"
      },
      "orchestrator_completion_summary": {
        "alert_level": "HEALTHY",
        "g2_applied": false
      }
    },
    "assert": [
      "HEALTHY format rendered with ✅ emoji",
      "Post sent to #revops-alignment",
      "No cc to #cs-leadership",
      "G2 disclaimer NOT included",
      "Completion summary shows HEALTHY",
      "hubspot_data_as_of timestamp present in alert",
      "csms_to_hire not shown (0)"
    ]
  },
  {
    "id": "cm-002",
    "label": "NEAR_CEILING threshold breach — HIGH alert with cc",
    "description": "CS headroom has dropped to 7%, crossing the 10% NEAR_CEILING threshold. Alert posts to primary channel and ccs CS leadership.",
    "input": {
      "practice_profile": {
        "company_name": "Meridian SaaS",
        "primary_segment": "Enterprise",
        "current_arr": 18500000,
        "arr_per_csm": 2000000,
        "current_csm_count": 10,
        "csm_avg_ramp_days": 120,
        "target_growth_pct": 0.25,
        "nrr_current": 1.12,
        "uog_baseline_path": "~/.cs-agent/uog-baseline.json"
      },
      "hubspot_connected": true,
      "preview_mode": false,
      "alert_channel": "#revops-alignment",
      "cc_channel": "#cs-leadership"
    },
    "expected_behavior": {
      "capacity_reader": {
        "max_supported_arr": 20000000,
        "cs_headroom_pct": 8.1,
        "threshold_label": "NEAR_CEILING",
        "alert_level": "HIGH",
        "csms_to_hire": 2,
        "hire_by_urgency": "OK",
        "confidence": "High"
      },
      "capacity_reporter": {
        "format_used": "HIGH",
        "channels_posted": ["#revops-alignment", "#cs-leadership"],
        "cc_channel_used": true,
        "g2_disclaimer_included": true,
        "delivery_status": "posted"
      }
    },
    "assert": [
      "HIGH format rendered with ⚠️ emoji",
      "G2 disclaimer included: 'This model is a structural input.'",
      "Post sent to both #revops-alignment and #cs-leadership",
      "UoG baseline section rendered (annual plan comparison)",
      "hire_by_date shown",
      "Confidence: High (HubSpot live + UoG baseline present)",
      "hubspot_data_as_of timestamp present"
    ]
  },
  {
    "id": "cm-003",
    "label": "OVER_CAPACITY — CRITICAL alert",
